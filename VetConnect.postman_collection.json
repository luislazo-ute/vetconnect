{
  "info": {
    "name": "VetConnect API",
    "description": "Colección de pruebas de la API VetConnect (Django REST Framework + JWT). Ejecuta primero Auth > Login: guarda automáticamente el access/refresh en variables de la colección.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "auth": {
    "type": "bearer",
    "bearer": [{ "key": "token", "value": "{{access}}", "type": "string" }]
  },
  "variable": [
    { "key": "base_url", "value": "https://vetconnect-api.uaeftt-ute.site" },
    { "key": "access", "value": "" },
    { "key": "refresh", "value": "" }
  ],
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Register",
          "request": {
            "auth": { "type": "noauth" },
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{base_url}}/api/auth/register/",
            "body": { "mode": "raw", "raw": "{\n  \"username\": \"ana\",\n  \"email\": \"ana@vet.com\",\n  \"password\": \"ClaveSegura123\",\n  \"password2\": \"ClaveSegura123\"\n}" }
          }
        },
        {
          "name": "Login",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const data = pm.response.json();",
                  "if (data.access) pm.collectionVariables.set('access', data.access);",
                  "if (data.refresh) pm.collectionVariables.set('refresh', data.refresh);"
                ]
              }
            }
          ],
          "request": {
            "auth": { "type": "noauth" },
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{base_url}}/api/auth/login/",
            "body": { "mode": "raw", "raw": "{\n  \"username\": \"admin\",\n  \"password\": \"Admin1234!\"\n}" }
          }
        },
        {
          "name": "Refresh token",
          "request": {
            "auth": { "type": "noauth" },
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{base_url}}/api/token/refresh/",
            "body": { "mode": "raw", "raw": "{\n  \"refresh\": \"{{refresh}}\"\n}" }
          }
        },
        {
          "name": "Verify token",
          "request": {
            "auth": { "type": "noauth" },
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{base_url}}/api/token/verify/",
            "body": { "mode": "raw", "raw": "{\n  \"token\": \"{{access}}\"\n}" }
          }
        },
        {
          "name": "Logout",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{base_url}}/api/auth/logout/",
            "body": { "mode": "raw", "raw": "{\n  \"refresh\": \"{{refresh}}\"\n}" }
          }
        }
      ]
    },
    {
